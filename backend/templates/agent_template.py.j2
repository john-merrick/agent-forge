#!/usr/bin/env python3
"""
{{ agent_name }}
Generated by Agent Forge (ID: {{ agent_id }})

{% if provider == 'ollama' -%}
Uses {{ model }} via local Ollama instance.
{% else -%}
Uses {{ model }} via OpenRouter API.
{% endif -%}
"""

import json
import os
import sys
import time

import httpx

# --- Configuration ---

MODEL = "{{ model }}"
PROVIDER = "{{ provider }}"

{% if provider == 'ollama' -%}
BASE_URL = os.environ.get("OLLAMA_BASE_URL", "http://localhost:11434")
API_URL = f"{BASE_URL}/api/chat"
{% else -%}
API_KEY = os.environ.get("OPENROUTER_API_KEY", "")
API_URL = "https://openrouter.ai/api/v1/chat/completions"
{% endif %}

SYSTEM_PROMPT = """{{ system_prompt | replace('"""', '\\"\\"\\"') }}"""

USER_PROMPT_TEMPLATE = """{{ user_prompt_template | replace('"""', '\\"\\"\\"') }}"""

{% if tools -%}
# --- Tool Definitions ---

TOOLS = [
{% for tool in tools %}
    {
        "type": "function",
        "function": {
            "name": "{{ tool }}",
            "description": "Execute the {{ tool }} tool",
            "parameters": {"type": "object", "properties": {}},
        },
    },
{% endfor %}
]
{% endif %}

def build_messages(user_input: str | None = None) -> list[dict]:
    messages = []
    if SYSTEM_PROMPT.strip():
        messages.append({"role": "system", "content": SYSTEM_PROMPT})
    prompt = USER_PROMPT_TEMPLATE
    if user_input:
        prompt = prompt.replace("{{ '{{input}}' }}", user_input)
    if prompt.strip():
        messages.append({"role": "user", "content": prompt})
    return messages


{% if provider == 'ollama' -%}
def call_model(messages: list[dict]) -> dict:
    """Call Ollama API."""
    payload = {
        "model": MODEL,
        "messages": messages,
        "stream": False,
    }
    with httpx.Client(timeout=120) as client:
        r = client.post(API_URL, json=payload)
        r.raise_for_status()
        return r.json()


def parse_response(raw: dict) -> dict:
    msg = raw.get("message", {})
    return {
        "content": msg.get("content", ""),
        "tokens_in": raw.get("prompt_eval_count", 0),
        "tokens_out": raw.get("eval_count", 0),
    }
{% else -%}
def call_model(messages: list[dict]) -> dict:
    """Call OpenRouter API."""
    if not API_KEY:
        print(json.dumps({"error": "OPENROUTER_API_KEY not set"}))
        sys.exit(1)
    headers = {
        "Authorization": f"Bearer {API_KEY}",
        "Content-Type": "application/json",
    }
    payload = {
        "model": MODEL,
        "messages": messages,
    }
    with httpx.Client(timeout=120) as client:
        r = client.post(API_URL, json=payload, headers=headers)
        r.raise_for_status()
        return r.json()


def parse_response(raw: dict) -> dict:
    choice = raw.get("choices", [{}])[0]
    usage = raw.get("usage", {})
    return {
        "content": choice.get("message", {}).get("content", ""),
        "tokens_in": usage.get("prompt_tokens", 0),
        "tokens_out": usage.get("completion_tokens", 0),
    }
{% endif %}

def run(user_input: str | None = None) -> dict:
    """Main entry point. Returns structured result."""
    start = time.time()
    messages = build_messages(user_input)
    raw = call_model(messages)
    result = parse_response(raw)
    result["model"] = MODEL
    result["provider"] = PROVIDER
    result["latency_ms"] = int((time.time() - start) * 1000)
    return result


if __name__ == "__main__":
    user_input = os.environ.get("AGENT_INPUT")
    if user_input:
        try:
            data = json.loads(user_input)
            user_input = data.get("input", user_input)
        except (json.JSONDecodeError, AttributeError):
            pass

    result = run(user_input)
    print(json.dumps(result, indent=2))
